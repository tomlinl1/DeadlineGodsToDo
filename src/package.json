{
  "name": "todoapp_mongoose",
  "version": "1.0.0",
  "description": "Todo app using Mongoose ODM",
  "main": "index.js",
  "scripts": {
    "start": "nodemon index.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:acceptance": "npx playwright test",
    "test:all": "npm test && npm run test:acceptance",
    "playwright:install": "npx playwright install"
  },
  "type": "module",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.3",
    "ejs": "^3.1.6",
    "express": "^4.17.2",
    "method-override": "^3.0.0",
    "mongoose": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "jest": "^30.1.3",
    "mongodb-memory-server": "^10.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
