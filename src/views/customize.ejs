<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Customize</title>
  </head>

  <body>
    <%- include('nav.ejs') %>

    <div class="container mt-4">
      <h3>Customize Appearance</h3>

      <div class="mt-3">
        <label class="form-label">Theme</label>

        <select id="themeSelect" class="form-select" style="max-width:300px">
          <option value="default">Default</option>
          <option value="dark">Dark</option>
          <option value="ocean">Ocean</option>
          <option value="porple">Porple</option>
          <option value="discord">Discord</option>
          <option value="mint">Mint</option>
        </select>
      </div>
    </div>

    <script>
      (function () {

        const select = document.getElementById("themeSelect");
        const username = localStorage.getItem("username");

        // -----------------------------
        // Apply theme instantly to page
        // -----------------------------
      
        function applyTheme(theme) {
          document.documentElement.setAttribute("data-theme", theme);
        }

        // LOCK / UNLOCK DROPDOWN BASED ON ACHIEVEMENTS
        function updateThemeDropdown(user) {
          const unlocked = user.customization?.unlockedThemes || [];

          Array.from(select.options).forEach(option => {
            const theme = option.value;

            const isUnlocked = unlocked.includes(theme);

            option.disabled = !isUnlocked;

            // reset text every time (VERY IMPORTANT)
            option.textContent = isUnlocked ? theme : `${theme} 🔒`;
          });
        }

        // -----------------------------
        // LOAD USER DATA FROM MONGODB
        // -----------------------------
        async function loadUserTheme() {
          try {
            const res = await fetch(`/api/users?user_id=${username}`);
            const user = await res.json();

            const theme = user.customization?.activeTheme || "default";

            select.value = theme;

            // lock/unlock UI
            updateThemeDropdown(user);

          } catch (err) {
            console.error("Failed to load theme:", err);

            select.value = "default";
            
            applyTheme("default");
          }
        }

        // -----------------------------
        // SAVE THEME TO MONGODB
        // -----------------------------
        async function saveTheme(theme) {
          try {
            await fetch(`/api/users/${username}/customization/theme`, {
              method: "PATCH",
              headers: {
                "Content-Type": "application/json"
              },
              body: JSON.stringify({ theme })
            });

          } catch (err) {
            console.error("Failed to save theme:", err);
          }
        }

        // -----------------------------
        // HANDLE USER CHANGES THEME
        // -----------------------------
        select.addEventListener("change", async () => {
          const theme = select.value;

          // apply
          applyTheme(theme);
          localStorage.setItem("theme", theme);
          
          // save in DB
          await saveTheme(theme)
        });

        // -----------------------------
        // INIT PAGE
        // -----------------------------
        loadUserTheme();

      })();
    </script>

  </body>
</html>