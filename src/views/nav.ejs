</nav>

<!-- ✅ Bootstrap 5 Modal -->
<div class="modal fade" id="achievementsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content" style="height: 70vh;">

      <!-- Header -->
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-1">Achievements </h5>
          <span id="userTotalPoints">Achievement Points: 0</span>
          <br>
          <!-- Filter buttons -->
          <div class="btn-group btn-group-sm">
            <button class="btn btn-secondary filter" data-type="all">All</button>
            <button class="btn btn-primary filter" data-type="general">General</button>
            <button class="btn btn-info filter" data-type="low">Low</button>
            <button class="btn btn-warning filter" data-type="medium">Medium</button>
            <button class="btn btn-danger filter" data-type="high">High</button>
          </div>
        </div>

        <!-- Points-->
        

        <!-- Close button -->
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        
      </div>

      <!-- Body -->
      <div id="achievementModalBody" class="modal-body">
        <!-- Dynamic content -->
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script>
  let achievementsData = [];

  // Fetch achievements by user_id
  async function fetchAchievementsByUsername(username) {
    try {
      const userRes = await fetch(`http://localhost:5500/api/users?user_id=${encodeURIComponent(username)}`);
      if (!userRes.ok) throw new Error("User not found");
      const user = await userRes.json();

      document.getElementById("userTotalPoints").textContent = `${user.total_points} Achievement Points`;
      const achievementsRes = await fetch(`http://localhost:5500/api/achievements/${user._id}`);
      if (!achievementsRes.ok) throw new Error("Could not fetch achievements");
      achievementsData = await achievementsRes.json();

      renderAchievements("all");
    } catch (err) {
      console.error(err);
      alert(err.message);
    }
  }

  function renderAchievements(type) {
    const container = document.getElementById('achievementModalBody');
    container.innerHTML = "";

    let filtered = (type === "all")
      ? achievementsData
      : achievementsData.filter(a => a.category && a.category.toLowerCase() === type.toLowerCase());

    let counter = 1;
    filtered.forEach(a => {
      const achieveDiv = document.createElement('div');
      achieveDiv.setAttribute('data-bs-toggle', 'collapse');
      achieveDiv.setAttribute('data-bs-target', `#achievement${counter}`);
      achieveDiv.setAttribute('aria-expanded', 'false');
      achieveDiv.setAttribute('aria-controls', `achievement${counter}`);
      achieveDiv.style.cursor = 'pointer';
      achieveDiv.innerText = a.name;

      const collapseDiv = document.createElement('div');
      collapseDiv.id = `achievement${counter}`;
      collapseDiv.classList.add('collapse');

      const card = document.createElement('div');
      card.classList.add('card', 'card-body');
      card.innerText = a.description;

      collapseDiv.appendChild(card);
      container.appendChild(achieveDiv);
      container.appendChild(collapseDiv);

      counter++;
    });
  }

  // Open achievements modal
  document.getElementById("openAchievements").addEventListener("click", () => {
    let username = localStorage.getItem("username");
    fetchAchievementsByUsername(username).then(() => {
      const modal = new bootstrap.Modal(document.getElementById('achievementsModal'));
      modal.show();
    });
  });

  // Filters
  document.querySelectorAll(".filter").forEach(span => {
    span.addEventListener("click", () => {
      renderAchievements(span.getAttribute("data-type"));
    });
  });
</script>

<script>
  (function () {

    const username = localStorage.getItem("username");
    document.getElementById("navUsername").textContent = username || "Guest";

    const authLink = document.getElementById("authLink");
    if (username) {
      authLink.textContent = "Logout";
      authLink.href = "#";
      authLink.addEventListener("click", () => {
        localStorage.removeItem("username");
        localStorage.removeItem("theme");
        window.location.href = "/";
      });
    }

    // -----------------------------
    // APPLY CACHED THEME (fast, no flicker)
    // -----------------------------
    const cachedTheme = localStorage.getItem("theme");
    if (cachedTheme) {
      document.documentElement.setAttribute("data-theme", cachedTheme);
    }

    // -----------------------------
    // FIX NAV LINKS
    // -----------------------------
    const listLink = document.getElementById("listLink");
    if (username) {
      listLink.href = `/list?username=${encodeURIComponent(username)}`;
    } else {
      listLink.addEventListener("click", (e) => {
        e.preventDefault();
        window.location.href = "/login";
      });
    }

    // -----------------------------
    // LOAD THEME FROM DATABASE
    // -----------------------------
    async function applyThemeFromDB() {
      if (!username) return;

      try {
        const res = await fetch(`/api/users?user_id=${username}`);
        const user = await res.json();

        const theme = user.customization?.activeTheme || "default";

        // apply theme
        document.documentElement.setAttribute("data-theme", theme);

        // cache it
        localStorage.setItem("theme", theme);

      } catch (err) {
        console.error("Theme load failed:", err);
      }
    }

    applyThemeFromDB();

    // -----------------------------
    // GLOBAL: COMPLETE ACHIEVEMENT
    // -----------------------------
    window.completeAchievement = async function (achievementId) {
      if (!username) return;

      try {
        const res = await fetch(
          `/api/achievements/${username}/complete/${achievementId}`,
          { method: "POST" }
        );

        const data = await res.json();

        console.log("Achievement updated:", data);
        alert("Achievement completed!");

      } catch (err) {
        console.error("Achievement error:", err);
      }
    };

  })();
</script>