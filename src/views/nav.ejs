<!-- ✅ Bootstrap 5 Modal -->
<div class="modal fade" id="achievementsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content" style="height: 70vh;">

      <!-- Header -->
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-1">Achievements </h5>
          <span id="userTotalPoints">Achievement Points: 0</span>
          <br>
          <!-- Filter buttons -->
          <div class="btn-group btn-group-sm">
            <button class="btn btn-secondary filter" data-type="all">All</button>
            <button class="btn btn-primary filter" data-type="general">General</button>
            <button class="btn btn-info filter" data-type="low">Low</button>
            <button class="btn btn-warning filter" data-type="medium">Medium</button>
            <button class="btn btn-danger filter" data-type="high">High</button>
          </div>
        </div>

        <!-- Points-->
        

        <!-- Close button -->
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        
      </div>

      <!-- Body -->
      <div id="achievementModalBody" class="modal-body">
        <!-- Dynamic content -->
      </div>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script>
  let achievementsData = [];
  let userCounters = [];

  const achievementProgress = {
    ach_01: { field: "total_tasks",        target: 1   },
    ach_02: { field: "total_tasks",        target: 5   },
    ach_03: { field: "total_tasks",        target: 10  },
    ach_04: { field: "total_tasks_low",    target: 1   },
    ach_05: { field: "total_tasks_low",    target: 5   },
    ach_06: { field: "total_tasks_medium", target: 1   },
    ach_07: { field: "total_tasks_medium", target: 5   },
    ach_08: { field: "total_tasks_high",   target: 1   },
    ach_09: { field: "total_tasks",        target: 100 },
  };

  const achievementUnlocks = {
    ach_01: "Default theme",
    ach_02: "Dark theme",
    ach_03: "Ocean theme",
    ach_04: "Porple theme",
    ach_05: "Discord theme",
    ach_06: "Mint theme",
    ach_07: null,
    ach_08: null,
    ach_09: null,
  };

  // Fetch achievements by user_id
  async function fetchAchievementsByUsername(username) {
  try {
    const userRes = await fetch(`http://localhost:5500/api/users?user_id=${encodeURIComponent(username)}`);
    if (!userRes.ok) throw new Error("User not found");
    const user = await userRes.json();

    document.getElementById("userTotalPoints").textContent = `Achievement Points: ${user.total_points}`;

    const achievementsRes = await fetch(`http://localhost:5500/api/achievements/${user._id}`);
    if (!achievementsRes.ok) throw new Error("Could not fetch achievements");

    const data = await achievementsRes.json();
    achievementsData = data.achievements;
    userCounters = data.counters;

    renderAchievements("all");
  } catch (err) {
    console.error(err);
    alert(err.message);
  }
}

  function renderAchievements(type) {
    const container = document.getElementById('achievementModalBody');
    container.querySelectorAll('.collapse').forEach(el => {
      const instance = bootstrap.Collapse.getInstance(el);
      if (instance) instance.dispose();
    });

  container.innerHTML = "";

    let filtered = (type === "all")
      ? achievementsData
      : achievementsData.filter(a => a.category && a.category.toLowerCase() === type.toLowerCase());

    let counter = 1;
    filtered.forEach(a => {
      const progress = achievementProgress[a.id];
      const current  = progress ? Math.min(userCounters[progress.field] || 0, progress.target) : 0;
      const target   = progress ? progress.target : 1;
      const pct      = Math.round((current / target) * 100);
      const isDone   = a.completed;

      // Wrapper
      const wrapper = document.createElement('div');
      wrapper.classList.add('p-2', 'border-bottom');

      // Collapsible header
      const header = document.createElement('div');
      //header.setAttribute('data-bs-toggle', 'collapse');
      header.setAttribute('data-bs-target', `#achievement-${a.id}`);
      header.setAttribute('aria-expanded', 'false');
      //header.setAttribute('aria-controls', `achievement-${a.id}`);
      header.style.cursor = 'pointer';
      header.classList.add('d-flex', 'justify-content-between', 'align-items-center');
      header.innerHTML = `
        <span>${isDone ? '✅' : '🔒'} ${a.name}</span>
        <small>${current} / ${target}</small>
      `;
      header.addEventListener('click', () => {
        const collapseEl = document.getElementById(`achievement-${a.id}`);
        const instance = bootstrap.Collapse.getOrCreateInstance(collapseEl, { toggle: false });
        instance.toggle();
      });

      // Progress bar
      const progressHTML = `
        <div class="progress mt-1" style="height: 6px;">
          <div class="progress-bar ${isDone ? 'bg-success' : 'bg-primary'}"
              role="progressbar"
              style="width: ${pct}%">
          </div>
        </div>
      `;

      // Collapse body with description
      const unlock = achievementUnlocks[a.id];
      const collapseDiv = document.createElement('div');
      collapseDiv.id = `achievement-${a.id}`;
      collapseDiv.classList.add('collapse');
      collapseDiv.innerHTML = `
        <div class="card card-body py-2 mt-1">
          <small>${a.description} — <strong>${a.points} pts</strong></small>
          ${unlock ? `<br><small>Unlocks: ${unlock}</small>` : ''}
        </div>
      `;

      wrapper.innerHTML = '';
      wrapper.appendChild(header);
      wrapper.insertAdjacentHTML('beforeend', progressHTML);
      wrapper.appendChild(collapseDiv);
      container.appendChild(wrapper);

      counter++;
    });
  }

  // Open achievements modal
  document.getElementById("openAchievements").addEventListener("click", () => {
    let username = localStorage.getItem("username");
    fetchAchievementsByUsername(username).then(() => {
      const modal = new bootstrap.Modal(document.getElementById('achievementsModal'));
      modal.show();
    });
  });

  // Filters
  document.querySelectorAll(".filter").forEach(span => {
    span.addEventListener("click", () => {
      renderAchievements(span.getAttribute("data-type"));
    });
  });
</script>

<script>
  (function () {

    const username = localStorage.getItem("username");
    document.getElementById("navUsername").textContent = username || "Guest";

    const authLink = document.getElementById("authLink");
    if (username) {
      authLink.textContent = "Logout";
      authLink.href = "#";
      authLink.addEventListener("click", () => {
        localStorage.removeItem("username");
        localStorage.removeItem("theme");
        window.location.href = "/";
      });
    }

    // -----------------------------
    // APPLY CACHED THEME (fast, no flicker)
    // -----------------------------
    const cachedTheme = localStorage.getItem("theme");
    if (cachedTheme) {
      document.documentElement.setAttribute("data-theme", cachedTheme);
    }

    // -----------------------------
    // FIX NAV LINKS
    // -----------------------------
    const listLink = document.getElementById("listLink");
    if (username) {
      listLink.href = `/list?username=${encodeURIComponent(username)}`;
    } else {
      listLink.addEventListener("click", (e) => {
        e.preventDefault();
        window.location.href = "/login";
      });
    }

    // -----------------------------
    // LOAD THEME FROM DATABASE
    // -----------------------------
    async function applyThemeFromDB() {
      if (!username) return;

      try {
        const res = await fetch(`/api/users?user_id=${username}`);
        const user = await res.json();

        const theme = user.customization?.activeTheme || "default";

        // apply theme
        document.documentElement.setAttribute("data-theme", theme);

        // cache it
        localStorage.setItem("theme", theme);

      } catch (err) {
        console.error("Theme load failed:", err);
      }
    }

    applyThemeFromDB();

    // -----------------------------
    // GLOBAL: COMPLETE ACHIEVEMENT
    // -----------------------------
    window.completeAchievement = async function (achievementId) {
      if (!username) return;

      try {
        const res = await fetch(
          `/api/achievements/${username}/complete/${achievementId}`,
          { method: "POST" }
        );

        const data = await res.json();

        console.log("Achievement updated:", data);
        alert("Achievement completed!");

      } catch (err) {
        console.error("Achievement error:", err);
      }
    };

  })();
</script>