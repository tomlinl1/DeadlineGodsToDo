<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap 5.3.8 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Your custom CSS -->
  <link rel="stylesheet" href="/public/css/styles.css">

  <title>Task Details</title>
</head>

<body>

  <%- include('nav.ejs') %>

  <div class="container mt-4">

    <div class="card shadow-sm">
      <div class="card-body detail-card">

        <!-- Title -->
        <h4 class="card-title mb-3">
          <%= data.title %>
        </h4>

        <!-- Due Date + Time -->
        <% if (data.date) { %>
          <% 
            const d = new Date(data.date);
            const datePart = d.toLocaleDateString('en-US');
            const timePart = d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
          %>
          <p class="mb-3">
            Due: <%= datePart %> at <%= timePart %>
          </p>
        <% } else { %>
          <p class="text-muted mb-3">No due date set</p>
        <% } %>

        <!-- Priority -->
        <% if (data.priority) { %>
          <p class="mb-3">
            <span class="badge bg-<%= data.priority === 'high' ? 'danger' : data.priority === 'medium' ? 'warning' : 'info' %>">
              <%= data.priority %>
            </span>
          </p>
        <% } %>

        <!-- Tags -->
        <% if (data.tags && data.tags.length > 0) { %>
          <div class="mb-3">
            <% data.tags.forEach(tag => { %>
              <span class="badge bg-secondary me-1"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>

        <!-- Actions -->
        <div class="d-flex gap-2">
          <a href="/edit/<%= data._id %>" class="btn btn-primary">Edit Task</a>
          <a href="/list" id="listLink2" class="btn btn-secondary">Back to List</a>
        </div>

      </div>
    </div>

  </div>

  <!-- Bootstrap JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const username = localStorage.getItem("username")
    if (username) {
      const listLink2 = document.getElementById("listLink2");
      if (listLink2) {
        listLink2.href = `/list?username=${encodeURIComponent(username)}`;
      }
    }
  </script>

</body>

</html>