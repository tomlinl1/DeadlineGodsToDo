<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Bootstrap 5.3.8 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Your custom CSS -->
  <link rel="stylesheet" href="/css/styles.css">

  <title>Task Details</title>
</head>

<body>

  <%- include('nav.ejs') %>

  <div class="container mt-4">

    <div class="card shadow-sm">
      <div class="card-body">

        <!-- Title -->
        <h4 class="card-title mb-2">
          <%= data.title %>
        </h4>

        <!-- Date -->
        <p class="text-muted mb-3">
          Due: <%= new Date(data.date).toLocaleDateString() %>
        </p>

        <!-- Optional: Priority -->
        <% if (data.priority) { %>
          <p>
            <span class="badge bg-<%= data.priority === 'high' ? 'danger' : data.priority === 'medium' ? 'warning' : 'info' %>">
              <%= data.priority %>
            </span>
          </p>
        <% } %>

        <!-- Optional: Tags -->
        <% if (data.tags && data.tags.length > 0) { %>
          <div class="mb-3">
            <% data.tags.forEach(tag => { %>
              <span class="badge bg-secondary"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>

        <!-- Actions -->
        <div class="d-flex gap-2">

          <a href="/edit/<%= data._id %>" class="btn btn-primary">
            Edit Task
          </a>

          <a href="/list" class="btn btn-outline-secondary">
            Back to List
          </a>

        </div>

      </div>
    </div>

  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>