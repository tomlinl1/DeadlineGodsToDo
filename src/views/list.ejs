<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>Task List - The Deadline Crusher</title>

    <style>
      .smart-nav .btn { margin-right: 5px; margin-bottom: 5px; }
      .filter-panel { background: #f8f9fa; padding: 15px; border-radius: 5px; margin-bottom: 20px; }
      .pinned-badge { font-size: 0.75rem; }
      .overdue { border-left: 4px solid #dc3545; }
      .due-today { border-left: 4px solid #ffc107; }
      .upcoming { border-left: 4px solid #28a745; }
      .saved-views-list .list-group-item { display: flex; justify-content: space-between; align-items: center; }
    </style>
  </head>

  <body>

    <%- include('nav.ejs') %>

    <div class="container mt-4">
      <h4><strong>Task List</strong></h4>

      <!-- Smart Nav -->
      <div class="smart-nav mb-3">
        <a href="/list?view=today" class="btn btn-outline-warning btn-sm <%= activeView === 'today' ? 'active' : '' %>">Today</a>
        <a href="/list?view=upcoming" class="btn btn-outline-success btn-sm <%= activeView === 'upcoming' ? 'active' : '' %>">Upcoming</a>
        <a href="/list?view=overdue" class="btn btn-outline-danger btn-sm <%= activeView === 'overdue' ? 'active' : '' %>">Overdue</a>
        <a href="/list" class="btn btn-outline-secondary btn-sm <%= activeView === 'all' ? 'active' : '' %>">All Tasks</a>
      </div>

      <!-- Search -->
      <form method="GET" action="/list" class="mb-3">
        <div class="input-group">
          <input type="text" class="form-control" name="search" placeholder="Search tasks..." value="<%= filters.search || '' %>" />

          <!-- Hidden Filters -->
          <input type="hidden" name="tag" value="<%= filters.tag || '' %>" />
          <input type="hidden" name="priority" value="<%= filters.priority || '' %>" />
          <input type="hidden" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
          <input type="hidden" name="dateTo" value="<%= filters.dateTo || '' %>" />
          <input type="hidden" name="sortBy" value="<%= sortBy || 'date' %>" />
          <input type="hidden" name="sortOrder" value="<%= sortOrder || 'asc' %>" />

          <button class="btn btn-outline-primary" type="submit">Search</button>
        </div>
      </form>

      <!-- Filters -->
      <div class="filter-panel">
        <form method="GET" action="/list">
          <div class="row g-2 align-items-end">

            <div class="col-md-2">
              <label class="form-label small">Tag</label>
              <select class="form-select form-select-sm" name="tag">
                <option value="">All Tags</option>
                <% allTags.forEach(tag => { %>
                  <option value="<%= tag %>" <%= filters.tag === tag ? 'selected' : '' %>><%= tag %></option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-2">
              <label class="form-label small">Priority</label>
              <select class="form-select form-select-sm" name="priority">
                <option value="">All</option>
                <option value="high" <%= filters.priority === 'high' ? 'selected' : '' %>>High</option>
                <option value="medium" <%= filters.priority === 'medium' ? 'selected' : '' %>>Medium</option>
                <option value="low" <%= filters.priority === 'low' ? 'selected' : '' %>>Low</option>
              </select>
            </div>

            <div class="col-md-2">
              <label class="form-label small">From</label>
              <input type="date" class="form-control form-control-sm" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
            </div>

            <div class="col-md-2">
              <label class="form-label small">To</label>
              <input type="date" class="form-control form-control-sm" name="dateTo" value="<%= filters.dateTo || '' %>" />
            </div>

            <div class="col-md-2">
              <label class="form-label small">Sort By</label>
              <select class="form-select form-select-sm" name="sortBy">
                <option value="date" <%= sortBy === 'date' ? 'selected' : '' %>>Due Date</option>
                <option value="title" <%= sortBy === 'title' ? 'selected' : '' %>>Title</option>
                <option value="priority" <%= sortBy === 'priority' ? 'selected' : '' %>>Priority</option>
              </select>
            </div>

            <div class="col-md-1">
              <label class="form-label small">Order</label>
              <select class="form-select form-select-sm" name="sortOrder">
                <option value="asc" <%= sortOrder === 'asc' ? 'selected' : '' %>>Asc</option>
                <option value="desc" <%= sortOrder === 'desc' ? 'selected' : '' %>>Desc</option>
              </select>
            </div>

            <div class="col-md-1">
              <button type="submit" class="btn btn-primary btn-sm w-100">Filter</button>
            </div>

          </div>

          <a href="/list" class="btn btn-link btn-sm p-0 mt-2">Clear Filters</a>
        </form>
      </div>

      <!-- Save View -->
      <form method="POST" action="/list/views/save" class="d-flex gap-2 mb-3">
        <input type="text" class="form-control form-control-sm" name="viewName" placeholder="View name..." required />
        <button type="submit" class="btn btn-outline-success btn-sm">Save View</button>
      </form>

      <!-- Saved Views -->
      <% if (savedViews && savedViews.length > 0) { %>
        <div class="mb-3">
          <h6>Saved Views</h6>
          <div class="list-group">
            <% savedViews.forEach(view => { %>
              <div class="list-group-item d-flex justify-content-between align-items-center py-1">

                <a href="/list/views/<%= view._id %>/load">
                  <%= view.name %>
                  <% if (view.pinned) { %>
                    <span class="badge bg-primary pinned-badge">Pinned</span>
                  <% } %>
                </a>

                <div class="d-flex gap-1">
                  <% if (!view.pinned) { %>
                    <form method="POST" action="/list/views/<%= view._id %>/pin">
                      <button class="btn btn-outline-primary btn-sm py-0">Pin</button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/list/views/<%= view._id %>/unpin">
                      <button class="btn btn-outline-secondary btn-sm py-0">Unpin</button>
                    </form>
                  <% } %>

                  <form method="POST" action="/list/views/<%= view._id %>/delete?_method=DELETE">
                    <button class="btn btn-outline-danger btn-sm py-0">X</button>
                  </form>
                </div>

              </div>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Count -->
      <p class="text-muted"><small><%= posts.length %> task(s) found</small></p>

      <!-- Tasks -->
      <ul class="list-group">
        <% if (posts.length === 0) { %>
          <li class="list-group-item text-center text-muted">No tasks found.</li>
        <% } %>

        <% var now = new Date(); now.setHours(0,0,0,0); %>

        <% posts.forEach(post => { 
          var dueDate = new Date(post.date);
          dueDate.setHours(0,0,0,0);
          var isOverdue = dueDate < now && !post.completed;
          var isToday = dueDate.getTime() === now.getTime();
          var rowClass = isOverdue ? 'overdue' : isToday ? 'due-today' : 'upcoming';
        %>

        <li class="list-group-item <%= rowClass %>">
          <div class="d-flex justify-content-between">

            <div>
              <h5>
                <a href="/detail/<%= post._id %>">
                  <% if (post.completed) { %><s><% } %>
                  <%= post.title %>
                  <% if (post.completed) { %></s><% } %>
                </a>
              </h5>

              <small class="text-muted">
                Due: <%= dueDate.toLocaleDateString() %>
                <% if (isOverdue) { %> <span class="text-danger fw-bold">OVERDUE</span><% } %>
                <% if (isToday) { %> <span class="text-warning fw-bold">TODAY</span><% } %>
              </small>

              <div class="mt-1">
                <span class="badge bg-<%= post.priority === 'high' ? 'danger' : post.priority === 'medium' ? 'warning' : 'info' %>">
                  <%= post.priority || 'medium' %>
                </span>

                <% if (post.tags) { post.tags.forEach(tag => { %>
                  <a href="/list?tag=<%= encodeURIComponent(tag) %>" class="badge bg-secondary"><%= tag %></a>
                <% }) } %>
              </div>
            </div>

            <div class="d-flex gap-2">
              <a href="/edit/<%= post._id %>" class="btn btn-outline-secondary btn-sm">Edit</a>
              <button class="delete btn btn-outline-danger btn-sm" data-id="<%= post._id %>">Delete</button>
            </div>

          </div>
        </li>

        <% }) %>
      </ul>

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
      document.querySelectorAll('.delete').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id;

          await fetch('/delete', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ _id: id })
          });

          btn.closest('li').remove();
        });
      });
    </script>

  </body>
</html>